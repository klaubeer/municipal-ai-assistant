    {
      "parameters": {
        "jsCode": "// Acessando os dados corretamente\nconst registros = items.map(item => item.json);  // Pega todos os dados do array 'items'\n\n// Inicializar variáveis para armazenar o número de ocorrências\nconst pesquisasPorAssunto = {\n  \"IPTU\": 0,\n  \"Secretária de Saúde\": 0,\n  \"Secretária de Turismo\": 0,\n  \"Secretária de Águas\": 0,\n  \"Secretária de Planejamento\": 0,\n  \"ISS\": 0,\n  \"Obras\": 0,\n  \"Prestação de Serviços\": 0,\n  \"Salários\": 0,\n  \"Contrato\": 0,\n  \"Coleta de Lixo\": 0,\n  \"Sanitário\": 0,\n  \"Alvarás\": 0,\n  \"Multa\": 0,\n  \"Licenciamento Ambiental\": 0,\n  \"Licitações\": 0,\n  \"Transporte Público\": 0,\n  \"Educacional\": 0,\n  \"Habitação\": 0,\n  \"Saúde Pública\": 0,\n  \"Segurança Pública\": 0,\n  \"Vigilância Sanitária\": 0,\n  \"Meio Ambiente\": 0,\n  \"Infraestrutura Urbana\": 0\n};\n\n// Definir palavras-chave para os assuntos\nconst palavrasChave = {\n  \"IPTU\": [\"IPTU\", \"iptu\"],\n  \"Secretária de Saúde\": [\"Secretária de Saúde\", \"saúde\", \"secretaria de saúde\"],\n  \"Secretária de Turismo\": [\"Secretária de Turismo\", \"turismo\", \"secretaria de turismo\"],\n  \"Secretária de Águas\": [\"Secretária de Águas\", \"águas\", \"secretaria de águas\"],\n  \"Secretária de Planejamento\": [\"Secretária de Planejamento\", \"planejamento\", \"secretaria de planejamento\"],\n  \"ISS\": [\"ISS\", \"imposto sobre serviços\", \"iss\"],\n  \"Obras\": [\"obras\", \"infraestrutura\", \"recapeamento\", \"construção\"],\n  \"Prestação de Serviços\": [\"prestação de serviços\", \"serviços\", \"serviços públicos\"],\n  \"Salários\": [\"salários\", \"remuneração\"],\n  \"Contrato\": [\"contrato\", \"contratos\", \"licitação\", \"contratação\"],\n  \"Coleta de Lixo\": [\"coleta de lixo\", \"limpeza pública\"],\n  \"Sanitário\": [\"sanitário\", \"saneamento\", \"esgoto\"],\n  \"Alvarás\": [\"alvarás\", \"licenciamento\", \"alvará de funcionamento\"],\n  \"Multa\": [\"multa\", \"penalidade\", \"infração\"],\n  \"Licenciamento Ambiental\": [\"licenciamento ambiental\", \"meio ambiente\"],\n  \"Licitações\": [\"licitação\", \"pregão eletrônico\", \"pregão\"],\n  \"Transporte Público\": [\"transporte público\", \"ônibus\", \"transporte coletivo\"],\n  \"Educacional\": [\"educação\", \"escola\", \"educacional\", \"escolas municipais\"],\n  \"Habitação\": [\"habitação\", \"moradia\", \"programa habitacional\"],\n  \"Saúde Pública\": [\"saúde pública\", \"hospitais\", \"unidades de saúde\"],\n  \"Segurança Pública\": [\"segurança pública\", \"polícia\", \"segurança\"],\n  \"Vigilância Sanitária\": [\"vigilância sanitária\", \"controle sanitário\", \"vigilância\"],\n  \"Meio Ambiente\": [\"meio ambiente\", \"sustentabilidade\", \"preservação ambiental\"],\n  \"Infraestrutura Urbana\": [\"infraestrutura urbana\", \"urbanismo\", \"recapeamento\"]\n};\n\n// Processar os registros\nregistros.forEach((registro) => {\n  if (registro.bot_message) {\n    const botMessage = registro.bot_message.toLowerCase();  // Converter para minúsculas\n\n    // Buscar palavras-chave e atribuir aos assuntos\n    Object.entries(palavrasChave).forEach(([categoria, palavras]) => {\n      palavras.forEach(palavra => {\n        if (botMessage.includes(palavra.toLowerCase())) {\n          pesquisasPorAssunto[categoria]++;\n        }\n      });\n    });\n  }\n});\n\n// Filtrar os assuntos com contagem maior que 0\nconst assuntosComResultado = Object.fromEntries(\n  Object.entries(pesquisasPorAssunto).filter(([key, value]) => value > 0)\n);\n\n// Retornar os resultados\nreturn [\n  {\n    json: {\n      pesquisasPorAssunto: assuntosComResultado\n    }\n  }\n];\n"
      },
