      ],
      "id": "cdb546b1-f542-48ab-9b3b-493f0c13afa1",
      "name": "Consultas por Período"
    },
    {
      "parameters": {
        "jsCode": "// Acessando os dados corretamente\nconst registros = items.map(item => item.json);  // Pega todos os dados do array 'items'\n\n// Inicializar variável para contar categorias\nconst pesquisasPorCategoria = {\n  \"Todos\": 0, \"Acórdão\": 0, \"Ata de registro de preços\": 0, \"Atas\": 0, \"Atos da Presidência\": 0, \"Atos de Mesa\": 0,\n  \"Audiências Públicas\": 0, \"Chamadas Públicas\": 0, \"Comunicados\": 0, \"Concursos\": 0, \"Contas Públicas\": 0, \"Contratos\": 0,\n  \"Convênios\": 0, \"Decisão\": 0, \"Decretos\": 0, \"Editais de Notificação\": 0, \"Edital\": 0, \"Empenhos\": 0, \"Estatutos\": 0,\n  \"Extratos Diversos\": 0, \"Instrução Normativa\": 0, \"Leilões\": 0, \"Leis\": 0, \"Licenciamento ambiental\": 0, \"Licitações\": 0,\n  \"Medida Provisória\": 0, \"Outras publicações\": 0, \"Portarias\": 0, \"Prestação de contas\": 0, \"Regimentos internos\": 0, \"Resoluções\": 0,\n  \"Sem categoria\": 0\n};\n\n// Palavras-chave\nconst palavrasChave = [\n  \"Todos\", \"Acórdão\", \"Ata de registro de preços\", \"Atas\", \"Atos da Presidência\", \"Atos de Mesa\", \"Audiências Públicas\",\n  \"Chamadas Públicas\", \"Comunicados\", \"Concursos\", \"Contas Públicas\", \"Contratos\", \"Convênios\", \"Decisão\", \"Decretos\",\n  \"Editais de Notificação\", \"Edital\", \"Empenhos\", \"Estatutos\", \"Extratos Diversos\", \"Instrução Normativa\", \"Leilões\",\n  \"Leis\", \"Licenciamento ambiental\", \"Licitações\", \"Medida Provisória\", \"Outras publicações\", \"Portarias\", \"Prestação de contas\",\n  \"Regimentos internos\", \"Resoluções\"\n].map(palavra => palavra.toLowerCase());\n\n// Processar registros\nregistros.forEach((registro) => {\n  if (registro.user_message) {\n    const mensagem = registro.user_message.toLowerCase();\n    let categoriaEncontrada = false;\n\n    palavrasChave.forEach((categoria, index) => {\n      if (mensagem.includes(categoria)) {\n        pesquisasPorCategoria[Object.keys(pesquisasPorCategoria)[index]]++;\n        categoriaEncontrada = true;\n      }\n    });\n\n    if (!categoriaEncontrada) {\n      pesquisasPorCategoria[\"Sem categoria\"]++;\n    }\n  }\n});\n\n// Filtrar categorias com contagem maior que 0\nconst categoriasComResultado = Object.fromEntries(\n  Object.entries(pesquisasPorCategoria).filter(([key, value]) => value > 0)\n);\n\n// Retornar as categorias com resultado maior que 0\nreturn [\n  {\n    json: {\n      categorias: Object.keys(categoriasComResultado),\n      resultados: Object.values(categoriasComResultado)\n    }\n  }\n];\n"
      },
