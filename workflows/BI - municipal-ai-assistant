    {
      "parameters": {
        "jsCode": "// Acessando os dados corretamente\nconst registros = items.map(item => item.json);\n\n// Inicializar variável para contar números únicos\nconst numerosWhatsApp = new Set();\n\n// Processar os registros\nregistros.forEach((registro) => {\n  numerosWhatsApp.add(registro.phone);\n});\n\n// Retornar o número de WhatsApp únicos\nreturn [\n  {\n    json: {\n      numerosWhatsApp: numerosWhatsApp.size\n    }\n  }\n];\n"
      },
