    {
      "parameters": {
        "jsCode": "// Acessando os dados corretamente\nconst registros = items.map(item => item.json);  // Pega todos os dados do array 'items'\n\n// Inicializar variáveis\nconst consultasPorPeriodo = { dia: 0, semana: 0, mes: 0, ano: 0 };\n\n// Definir funções auxiliares\nconst hoje = new Date();\nconst obterPeriodo = (data) => {\n  const diffTime = hoje - new Date(data);\n  if (diffTime <= 86400000) consultasPorPeriodo.dia++;\n  if (diffTime <= 604800000) consultasPorPeriodo.semana++;\n  if (diffTime <= 2592000000) consultasPorPeriodo.mes++;\n  if (diffTime <= 31536000000) consultasPorPeriodo.ano++;\n};\n\n// Processar os registros\nregistros.forEach((registro) => {\n  obterPeriodo(registro.created_at);\n});\n\n// Retornar os resultados\nreturn [\n  {\n    json: {\n      consultasPorPeriodo: [\n        consultasPorPeriodo.dia,\n        consultasPorPeriodo.semana,\n        consultasPorPeriodo.mes,\n        consultasPorPeriodo.ano\n      ]\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
