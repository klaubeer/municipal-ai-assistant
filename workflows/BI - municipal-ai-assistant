    {
      "parameters": {
        "jsCode": "// Acessando os dados corretamente\n// NOTA: Para este nó 'Code' receber mais registros, o nó Supabase ANTERIOR a ele\n// (o nó que busca os dados brutos, provavelmente \"Supabase\") deve ser configurado\n// para buscar mais de 1000 registros, se necessário, ou um número suficiente\n// para garantir que haja 20 mensagens com mais de 15 caracteres.\n// Por padrão, o nó Supabase no seu workflow está com limit: 1000.\n// Se as mensagens mais antigas (fora dos 1000) forem relevantes, você precisaria\n// ajustar o 'limit' no nó 'Supabase' para um número maior.\nconst registros = items.map(item => item.json);\n\n// 1. Filtrar registros por 'user_message' com mais de 15 caracteres\n//    e que a user_message não seja nula ou vazia.\nconst filteredRegistros = registros.filter(registro => {\n  return registro.user_message && registro.user_message.length > 15;\n});\n\n// 2. Ordenar os registros filtrados por data de criação em ordem decrescente\n//    (do mais recente para o mais antigo)\nfilteredRegistros.sort((a, b) => {\n  const dateA = new Date(a.created_at);\n  const dateB = new Date(b.created_at);\n  return dateB.getTime() - dateA.getTime(); // Ordena do mais novo para o mais antigo\n});\n\n// 3. Pegar as 20 últimas consultas (que agora são as 20 primeiras após a ordenação e filtro)\nconst ultimasConsultas = filteredRegistros.slice(0, 20).map((registro) => {\n  const originalDate = new Date(registro.created_at);\n  \n  // Subtrai EXATAMENTE 3 horas (3 * 60 minutos * 60 segundos * 1000 milissegundos)\n  const offsetMs = 3 * 60 * 60 * 1000; \n  const adjustedDate = new Date(originalDate.getTime() - offsetMs);\n\n  // Formatar a data para exibição\n  const formattedTimestamp = adjustedDate.toLocaleString('pt-BR', {\n      dateStyle: 'short',\n      timeStyle: 'short'\n  });\n\n  return {\n    timestamp: formattedTimestamp,\n    query: registro.user_message\n  };\n});\n\n// Retornar os resultados\nreturn [\n  {\n    json: {\n      ultimasConsultas\n    }\n  }\n];"
      },
